@prefix ex: <http://example.org/> .
@prefix exato-wf: <https://w3id.org/Exa-AToW/exato-wf.ttl#> .
@prefix exato-wf-cwl: <https://raw.githubusercontent.com/cnherrera/Exa-AToW_onto/refs/heads/main/workflow_ontology/exato-wf-cwl-extension.ttl#> .
##@prefix inst: <https://w3id.org/Exa-AToW/instances/> .
@prefix inst: <https://raw.githubusercontent.com/cnherrera/Exa-AToW_onto/refs/heads/main/workflow_ontology/instances.ttl/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix qudt: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix wfdesc: <http://purl.org/wf4ever/wfdesc#> .

inst:kinetic_energy_workflow a exato-wf-cwl:CWLWorkflow ;
    rdfs:label "Kinetic Energy Workflow" ;
    wfdesc:hasInput inst:kinetic_energy_workflow_input_distance,
        inst:kinetic_energy_workflow_input_mass,
        inst:kinetic_energy_workflow_input_time ;
    wfdesc:hasOutput inst:kinetic_energy_workflow_output_kinetic_energy ;
    rdfs:comment "Computes kinetic energy from distance, time, and mass using intermediate speed calculation." ;
    exato-wf:hasStep inst:kinetic_energy_workflow_step_get_kinetic_energy,
        inst:kinetic_energy_workflow_step_get_speed .

inst:get_kinetic_energy_tool a exato-wf-cwl:CWLCommandLineTool ;
    rdfs:label "get_kinetic_energy" ;
    wfdesc:hasInput <https://w3id.org/Exa-AToW/instances/get_kinetic_energy_tool/input/mass>,
        <https://w3id.org/Exa-AToW/instances/get_kinetic_energy_tool/input/velocity> ;
    wfdesc:hasOutput <https://w3id.org/Exa-AToW/instances/get_kinetic_energy_tool/output/kinetic_energy> .

<https://w3id.org/Exa-AToW/instances/get_kinetic_energy_tool/input/mass> a exato-wf-cwl:CWLInputParameter ;
    ex:uri ex:Mass ;
    schema:unitCode qudt:KiloGM .

<https://w3id.org/Exa-AToW/instances/get_kinetic_energy_tool/input/velocity> a exato-wf-cwl:CWLInputParameter ;
    ex:uri ex:Velocity ;
    schema:unitCode qudt:M-PER-SEC .

<https://w3id.org/Exa-AToW/instances/get_kinetic_energy_tool/output/kinetic_energy> a exato-wf-cwl:CWLOutputParameter ;
    ex:uri ex:KineticEnergy ;
    schema:unitCode qudt:J .

inst:get_speed_tool a exato-wf-cwl:CWLCommandLineTool ;
    rdfs:label "get_speed" ;
    wfdesc:hasInput <https://w3id.org/Exa-AToW/instances/get_speed_tool/input/distance>,
        <https://w3id.org/Exa-AToW/instances/get_speed_tool/input/time> ;
    wfdesc:hasOutput <https://w3id.org/Exa-AToW/instances/get_speed_tool/output/speed> ;
    rdfs:comment "some random docstring" .

<https://w3id.org/Exa-AToW/instances/get_speed_tool/input/distance> a exato-wf-cwl:CWLInputParameter ;
    ex:uri ex:distance ;
    schema:unitCode qudt:M .

<https://w3id.org/Exa-AToW/instances/get_speed_tool/input/time> a exato-wf-cwl:CWLInputParameter ;
    ex:uri ex:time ;
    schema:unitCode qudt:SEC .

<https://w3id.org/Exa-AToW/instances/get_speed_tool/output/speed> a exato-wf-cwl:CWLOutputParameter ;
    ex:uri ex:speed ;
    schema:unitCode qudt:M-PER-SEC .

inst:kinetic_energy_workflow_input_distance a exato-wf-cwl:CWLInputParameter ;
    rdfs:label "Distance" ;
    ex:uri ex:distance ;
    exato-wf-cwl:hasType "float" ;
    schema:unitCode qudt:M .

inst:kinetic_energy_workflow_input_mass a exato-wf-cwl:CWLInputParameter ;
    rdfs:label "Mass" ;
    ex:uri ex:Mass ;
    exato-wf-cwl:hasType "float" ;
    schema:unitCode qudt:KiloGM .

inst:kinetic_energy_workflow_input_time a exato-wf-cwl:CWLInputParameter ;
    rdfs:label "Time" ;
    ex:uri ex:time ;
    exato-wf-cwl:hasType "float" ;
    schema:unitCode qudt:SEC .

inst:kinetic_energy_workflow_output_kinetic_energy a exato-wf-cwl:CWLOutputParameter ;
    rdfs:label "Kinetic Energy" ;
    ex:uri ex:KineticEnergy ;
    schema:unitCode qudt:J .

inst:kinetic_energy_workflow_step_get_kinetic_energy a exato-wf-cwl:CWLWorkflowStep ;
    rdfs:label "Compute Kinetic Energy" ;
    rdfs:comment "Computes 0.5 * mass * velocity^2" ;
    prov:wasAssociatedWith inst:get_kinetic_energy_tool .

inst:kinetic_energy_workflow_step_get_speed a exato-wf-cwl:CWLWorkflowStep ;
    rdfs:label "Compute Speed" ;
    rdfs:comment "Divides distance by time to produce speed in meter/second" ;
    prov:wasAssociatedWith inst:get_speed_tool .

